{
  "permissions": { "defaultMode": "default" },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command",
                    "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-bash.sh",
                    "timeout": 10 }]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command",
                    "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/protect-paths-and-secrets.sh",
                    "timeout": 10 }]
      }
    ]
  }
}
