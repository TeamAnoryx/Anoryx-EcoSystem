{
  "name": "anoryx-delta-admin-console",
  "version": "0.1.0",
  "private": true,
  "description": "Anoryx Delta budget-allocation admin console (D-007). Consumes the /v1/admin/* API; the admin token is server-side only.",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:render": "vitest run --config vitest.render.config.ts",
    "test:watch": "vitest",
    "check:token": "node scripts/check-token-absence.mjs"
  },
  "dependencies": {
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.35",
    "jsdom": "^29.1.1",
    "postcss": "8.4.41",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.3",
    "vitest": "2.0.5"
  }
}
