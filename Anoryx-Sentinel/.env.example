# Privileged role — migrations, hash chain ops, break-glass admin
DATABASE_URL=postgresql://sentinel:<password>@localhost:5432/sentinel_dev

# Non-privileged app role — all tenant traffic (NOBYPASSRLS)
APP_DATABASE_URL=postgresql://sentinel_app:<password>@localhost:5432/sentinel_dev

# HMAC secret for virtual API key fingerprints (64 hex chars)
SENTINEL_KEY_SECRET=<64-hex-char-secret>

# Opt-in for local dev: provision sentinel_app password on test startup
# Set to 1 only in local/CI ephemeral environments. NEVER in prod.
SENTINEL_PROVISION_APP_ROLE=0

# Claude Code OAuth token (fleet dispatch)
CLAUDE_CODE_OAUTH_TOKEN=<your-oauth-token>